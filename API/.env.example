# Google Cloud Storage Configuration
GCS_PROJECT_ID=your-project-id-here
GCS_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourBase64Key...\n-----END PRIVATE KEY-----\n"
GCS_BUCKET_NAME=aipeer_videos

# Identity Platform (required for SMS 2FA)
IDENTITY_PLATFORM_API_KEY=your-identity-platform-api-key

# Server Configuration
PORT=3000
NODE_ENV=development
